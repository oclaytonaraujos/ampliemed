# AmplieMed Environment Variables
# Copy this file to .env.local and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Get these from: https://app.supabase.com/project/[your-project-id]/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION & SECURITY
# ═══════════════════════════════════════════════════════════════════════════════

# JWT secret for token verification (server-side only)
VITE_JWT_SECRET=your-secret-key

# Rate limiting configuration
VITE_RATE_LIMIT_MAX_ATTEMPTS=5
VITE_RATE_LIMIT_WINDOW_MS=900000

# ═══════════════════════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# API base URL for backend requests
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=10000

# ═══════════════════════════════════════════════════════════════════════════════
# MONITORING & ERROR TRACKING
# ═══════════════════════════════════════════════════════════════════════════════

# Sentry error tracking (optional)
# Get from: https://sentry.io/organizations/
REACT_APP_SENTRY_DSN=https://key@sentry.io/project-id

# LogRocket session replay (optional)
REACT_APP_LOGROCKET_ID=your-logrocket-id

# ═══════════════════════════════════════════════════════════════════════════════
# THIRD-PARTY INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Google Maps API for address autocomplete
REACT_APP_GOOGLE_MAPS_API_KEY=your-api-key

# Stripe for payment processing (optional)
REACT_APP_STRIPE_PUBLIC_KEY=pk_live_...
REACT_APP_STRIPE_SECRET_KEY=sk_live_...

# SendGrid for email (optional)
VITE_SENDGRID_API_KEY=SG.xxxxx...

# Twilio for SMS (optional)
VITE_TWILIO_ACCOUNT_SID=ACxxxxx
VITE_TWILIO_AUTH_TOKEN=xxxxx
VITE_TWILIO_PHONE_NUMBER=+5511999999999

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURES & FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable/disable features
REACT_APP_FEATURE_TELEMEDICINE=true
REACT_APP_FEATURE_FINANCIAL_REPORTS=true
REACT_APP_FEATURE_AUDIT_LOG=true
REACT_APP_FEATURE_DARK_MODE=true
REACT_APP_FEATURE_PAYMENT_STRIPE=false

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Environment
VITE_ENVIRONMENT=development
NODE_ENV=development

# Application name and version
VITE_APP_NAME=AmplieMed
VITE_APP_VERSION=2.0.0

# Debug mode (enables verbose logging)
VITE_DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════════
# LOCALE & TIMEZONE
# ═══════════════════════════════════════════════════════════════════════════════

VITE_LOCALE=pt-BR
VITE_TIMEZONE=America/Sao_Paulo

# ═══════════════════════════════════════════════════════════════════════════════
# STORAGE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Max file upload size (in MB)
VITE_MAX_FILE_SIZE=10

# Allowed file types for upload
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.png,.jpeg

# ═══════════════════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════════════════
# 
# - Variables prefixed with VITE_ are exposed to the browser
# - Variables prefixed with REACT_APP_ work with Create React App
# - Never commit this file with real values to version control
# - Keep .env.local in .gitignore
# - Use .env.example as a template for all developers
#
