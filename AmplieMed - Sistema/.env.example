# ═══════════════════════════════════════════════════════════════════════════════
# AmplieMed — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️ Copy this file to .env and fill in YOUR values
# DO NOT commit .env with real credentials — it's in .gitignore

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION — SINCRONIZAÇÃO GLOBAL DE CONEXÕES
# ═══════════════════════════════════════════════════════════════════════════════
# Get these from: https://app.supabase.com/project/[project-id]/settings/api

# Project Information
VITE_SUPABASE_PROJECT_NAME=AMPLIEMED
VITE_SUPABASE_PROJECT_ID=suycrqtvipfzrkcmopua
VITE_SUPABASE_URL=https://your_project_id.supabase.co

# API Keys — Frontend (Client-Side)
# The anon key is safe to expose in the browser
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Secret — Backend (Server-Side Admin)
# ⚠️ NEVER expose this in frontend code or commit to repository
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════════════════════════
# STRIPE API KEYS — PAYMENT PROCESSING
# ═══════════════════════════════════════════════════════════════════════════════
# Get these from: https://dashboard.stripe.com/apikeys

# Publishable key — safe for frontend
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_... or pk_test_...

# Secret key — backend only
VITE_STRIPE_SECRET_KEY=sk_live_... or sk_test_...

# ═══════════════════════════════════════════════════════════════════════════════
# JWT CONFIGURATION — TOKEN SIGNING & VERIFICATION
# ═══════════════════════════════════════════════════════════════════════════════

# Current JWT secret for signing new tokens
VITE_JWT_SECRET=your_jwt_secret_here

# Previous JWT secret (for validating old tokens)
VITE_JWT_SECRET_PREVIOUS=your_previous_jwt_secret_here

# Legacy JWT secret (deprecated, for compatibility)
VITE_JWT_SECRET_LEGACY=your_legacy_jwt_secret_here

# Access token expiration in seconds (typically 3600 = 1 hour)
VITE_JWT_ACCESS_TOKEN_EXPIRY=3600

# ═══════════════════════════════════════════════════════════════════════════════
# EDGE FUNCTIONS — SERVERLESS FUNCTIONS
# ═══════════════════════════════════════════════════════════════════════════════
# Get these from: Supabase Dashboard → Settings → Edge Functions

# Access token for deploying/invoking functions
VITE_EDGE_FUNCTION_ACCESS_TOKEN=sbp_...

# Base URL for Edge Functions
VITE_EDGE_FUNCTION_URL=https://your_project_id.supabase.co/functions/v1

# Edge Function Secret credentials
VITE_EDGE_FUNCTION_SECRET_EMAIL=your_email@example.com
VITE_EDGE_FUNCTION_SECRET_PASSWORD=your_secure_password_here

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION — POSTGRESQL CONNECTION
# ═══════════════════════════════════════════════════════════════════════════════
# Direct PostgreSQL connection for server-side operations

# Database password
DATABASE_PASSWORD=your_database_password_here

# Direct connection string for PostgreSQL (includes password)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your_password@db.suycrqtvipfzrkcmopua.supabase.co:5432/postgres

# Database connection parameters (parsed from DATABASE_URL)
DATABASE_HOST=db.suycrqtvipfzrkcmopua.supabase.co
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_NAME=postgres

# ═══════════════════════════════════════════════════════════════════════════════
# ERROR TRACKING — SENTRY (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

VITE_SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

VITE_FEATURE_TELEMEDICINE=true
VITE_FEATURE_FINANCIAL_REPORTS=true
VITE_FEATURE_AUDIT_LOG=true
VITE_FEATURE_DARK_MODE=true

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

VITE_APP_NAME=AmplieMed
VITE_ENVIRONMENT=development
NODE_ENV=development
VITE_DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════════
# LOCALE & TIMEZONE
# ═══════════════════════════════════════════════════════════════════════════════

VITE_LOCALE=pt-BR
VITE_TIMEZONE=America/Sao_Paulo

# ═══════════════════════════════════════════════════════════════════════════════
# FILE UPLOAD
# ═══════════════════════════════════════════════════════════════════════════════

VITE_MAX_FILE_SIZE=10
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.png,.jpeg

# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️ SECURITY NOTES
# ═══════════════════════════════════════════════════════════════════════════════
# 
# 1. NEVER commit sensitive values to version control
# 2. Keep .env in .gitignore
# 3. Service Role Key is ADMIN-ONLY — never expose in frontend
# 4. JWT Secrets must be strong and random
# 5. Edge Function Secrets are environment variables for backend only
# 6. Use different values for dev/staging/production
# 
# To generate a secure random secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
