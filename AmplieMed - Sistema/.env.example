# ═══════════════════════════════════════════════════════════════════════════════
# AmplieMed — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in YOUR values
# DO NOT commit .env with real credentials — it's in .gitignore
#
# IMPORTANT: Variables prefixed with VITE_ are bundled into the frontend JS.
# Secret keys MUST NOT use the VITE_ prefix — they are backend-only.

# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Get these from: https://app.supabase.com/project/[project-id]/settings/api

# Project Information (frontend-safe)
VITE_SUPABASE_PROJECT_NAME=AMPLIEMED
VITE_SUPABASE_PROJECT_ID=suycrqtvipfzrkcmopua
VITE_SUPABASE_URL=https://your_project_id.supabase.co

# API Keys — Frontend (Client-Side, safe to expose)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Secret — BACKEND ONLY (no VITE_ prefix!)
# Used by Edge Functions via Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")
# NEVER import this in frontend code — it bypasses all RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════════════════════════
# STRIPE API KEYS — PAYMENT PROCESSING
# ═══════════════════════════════════════════════════════════════════════════════
# Get these from: https://dashboard.stripe.com/apikeys

# Publishable key — safe for frontend
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_... or pk_test_...

# Secret key — BACKEND ONLY (no VITE_ prefix!)
STRIPE_SECRET_KEY=sk_live_... or sk_test_...

# ═══════════════════════════════════════════════════════════════════════════════
# JWT CONFIGURATION — TOKEN SIGNING & VERIFICATION
# ═══════════════════════════════════════════════════════════════════════════════

# JWT secrets — BACKEND ONLY (no VITE_ prefix!)
JWT_SECRET=your_jwt_secret_here
JWT_SECRET_PREVIOUS=your_previous_jwt_secret_here
JWT_SECRET_LEGACY=your_legacy_jwt_secret_here

# Access token expiration in seconds (safe for frontend)
VITE_JWT_ACCESS_TOKEN_EXPIRY=3600

# ═══════════════════════════════════════════════════════════════════════════════
# EDGE FUNCTIONS — SERVERLESS FUNCTIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Base URL for Edge Functions (frontend-safe)
VITE_EDGE_FUNCTION_URL=https://your_project_id.supabase.co/functions/v1

# Edge Function credentials — BACKEND ONLY (no VITE_ prefix!)
EDGE_FUNCTION_ACCESS_TOKEN=sbp_...
EDGE_FUNCTION_SECRET_EMAIL=your_email@example.com
EDGE_FUNCTION_SECRET_PASSWORD=your_secure_password_here

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION — BACKEND ONLY (no VITE_ prefix!)
# ═══════════════════════════════════════════════════════════════════════════════

DATABASE_PASSWORD=your_database_password_here
DATABASE_URL=postgresql://postgres:your_password@db.suycrqtvipfzrkcmopua.supabase.co:5432/postgres
DATABASE_HOST=db.suycrqtvipfzrkcmopua.supabase.co
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_NAME=postgres

# ═══════════════════════════════════════════════════════════════════════════════
# EVOLUTION API — WHATSAPP INTEGRATION (BACKEND ONLY, no VITE_ prefix!)
# ═══════════════════════════════════════════════════════════════════════════════
# Get these from your self-hosted Evolution API v2 instance.
# Docs: https://doc.evolution-api.com

# Base URL of your Evolution API server (no trailing slash)
# Used by Edge Functions via Deno.env.get("EVOLUTION_API_URL")
EVOLUTION_API_URL=https://your-evolution-api.example.com

# Global API key from AUTHENTICATION_API_KEY in your Evolution .env
EVOLUTION_API_KEY=your-evolution-global-api-key

# Base URL for the webhook receiver Edge Function.
# Evolution API will POST events to: {EVOLUTION_WEBHOOK_BASE_URL}/{clinicId}/{token}
# Defaults to {SUPABASE_URL}/functions/v1/evolution_webhook if not set.
EVOLUTION_WEBHOOK_BASE_URL=https://your_project_id.supabase.co/functions/v1/evolution_webhook

# ═══════════════════════════════════════════════════════════════════════════════
# ERROR TRACKING — SENTRY (Optional, frontend-safe)
# ═══════════════════════════════════════════════════════════════════════════════

VITE_SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS (frontend-safe)
# ═══════════════════════════════════════════════════════════════════════════════

VITE_FEATURE_TELEMEDICINE=true
VITE_FEATURE_FINANCIAL_REPORTS=true
VITE_FEATURE_AUDIT_LOG=true
VITE_FEATURE_DARK_MODE=true

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

VITE_APP_NAME=AmplieMed
VITE_ENVIRONMENT=development
NODE_ENV=development
VITE_DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════════
# LOCALE & TIMEZONE
# ═══════════════════════════════════════════════════════════════════════════════

VITE_LOCALE=pt-BR
VITE_TIMEZONE=America/Sao_Paulo

# ═══════════════════════════════════════════════════════════════════════════════
# FILE UPLOAD
# ═══════════════════════════════════════════════════════════════════════════════

VITE_MAX_FILE_SIZE=10
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.png,.jpeg

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY NOTES
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. NEVER commit sensitive values to version control
# 2. Keep .env in .gitignore
# 3. Variables with VITE_ prefix ARE bundled into the frontend JS
# 4. Secret keys MUST NOT have the VITE_ prefix — backend only
# 5. Edge Functions access secrets via Deno.env.get() (no VITE_ prefix)
# 6. Use different values for dev/staging/production
#
# To generate a secure random secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
